/* ===================================
   CLIMBING.IN Portfolio CSS
   =================================== */

/* Reset & Base Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --neon-green: #B8FF3C;
    --dark-bg: #1a1a1a;
    --darker-bg: #0f0f0f;
    --cream: #F5F0E8;
    --pink: #D64C7F;
    --pink-light: #E57FA0;
}

body {
    font-family: 'Work Sans', sans-serif;
    background-color: var(--darker-bg);
    color: var(--cream);
    overflow-x: hidden;
    line-height: 1.6;
}

html {
    scroll-behavior: smooth;
}

/* ===================================
   LOADING SCREEN
   =================================== */
.loading-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--darker-bg);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.5s ease, visibility 0.5s ease;
}

.loading-screen.hidden {
    opacity: 0;
    visibility: hidden;
}

.loading-content {
    text-align: center;
}

.loading-gif {
    width: 150px;
    height: 150px;
    margin-bottom: 20px;
}

.loading-text {
    font-family: 'Rubik Vinyl', cursive;
    font-size: 2rem;
    color: var(--neon-green);
    letter-spacing: 3px;
}

/* ===================================
   MENU BUTTON & DROPDOWN
   =================================== */
.menu-button {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 1000;
    background: transparent;
    border: none;
    color: var(--neon-green);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: 'Work Sans', sans-serif;
}

.menu-icon {
    stroke: var(--neon-green);
}

.menu-button:hover {
    transform: scale(1.1);
}

.menu-dropdown {
    position: fixed;
    top: 5rem;
    left: 2rem;
    background: var(--dark-bg);
    border: 2px solid var(--neon-green);
    border-radius: 10px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
}

.menu-dropdown.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}

.menu-item {
    color: var(--cream);
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 5px;
    transition: all 0.3s ease;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.9rem;
}

.menu-item:hover {
    background-color: var(--neon-green);
    color: var(--darker-bg);
}

/* ===================================
   FLIP CARD BASE (Reusable)
   =================================== */
.flip-card {
    perspective: 1000px;
    cursor: pointer;
    transition: transform 0.3s ease;
}

.flip-card:hover {
    transform: scale(1.05);
}

.flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    transform-style: preserve-3d;
}

.flip-card.flipped .flip-card-inner,
.flip-card:hover .flip-card-inner {
    transform: rotateY(180deg);
}

.flip-card-front,
.flip-card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    border-radius: 15px;
}

.flip-card-front {
    background: transparent;
}

.flip-card-back {
    transform: rotateY(180deg);
}

.flip-card-front img,
.flip-card-back img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

/* Wiggle Animation */
@keyframes wiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-0.5deg); }
    75% { transform: rotate(0.5deg); }
}

/* ===================================
   HERO SECTION - Flipping Stickers
   =================================== */
.hero-sticker-section {
    min-height: 100vh;
    background-color: var(--darker-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 4rem 2rem;
}

.container {
    position: relative;
    width: 100%;
    max-width: 700px;
    height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

/* Central Image */
.image-flip {
    width: 350px;
    height: 350px;
    position: relative;
    z-index: 5;
}

.image-flip .flip-card-front,
.image-flip .flip-card-back {
    border-radius: 50%;
    overflow: hidden;
    border: 8px solid #fff;
    background: white;
}

.image-flip .flip-card-front img,
.image-flip .flip-card-back img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
}

/* Stickers */
.sticker {
    position: absolute;
    animation: wiggle 4s ease-in-out infinite;
}

.sticker:hover {
    animation-play-state: paused;
    z-index: 100;
}

.sticker-1 {
    top: 80px;
    left: 50px;
    width: auto;
    height: auto;
    max-width: 150px;
    animation-delay: 0s;
}

.sticker-1 .flip-card-inner {
    transform: rotate(-15deg);
}

.sticker-1:hover .flip-card-inner {
    transform: rotate(-15deg) rotateY(180deg);
}

.sticker-2 {
    top: 60px;
    right: 50px;
    width: auto;
    height: auto;
    max-width: 180px;
    animation-delay: 0.5s;
}

.sticker-2 .flip-card-inner {
    transform: rotate(8deg);
}

.sticker-2:hover .flip-card-inner {
    transform: rotate(8deg) rotateY(180deg);
}

.sticker-3 {
    top: 220px;
    left: 30px;
    width: auto;
    height: auto;
    max-width: 160px;
    animation-delay: 1s;
}

.sticker-3 .flip-card-inner {
    transform: rotate(-5deg);
}

.sticker-3:hover .flip-card-inner {
    transform: rotate(-5deg) rotateY(180deg);
}

.sticker-4 {
    top: 200px;
    right: 40px;
    width: auto;
    height: auto;
    max-width: 170px;
    animation-delay: 1.5s;
}

.sticker-4 .flip-card-inner {
    transform: rotate(12deg);
}

.sticker-4:hover .flip-card-inner {
    transform: rotate(12deg) rotateY(180deg);
}

/* Logo/Banner */
.logo-flip {
    width: 100%;
    max-width: 600px;
    height: 120px;
    position: relative;
    margin-top: 50px;
}

.logo-flip .flip-card-front {
    background: linear-gradient(135deg, #f5f5dc, #e8e8c8);
    border: 5px solid #4a9eff;
    border-radius: 20px;
}

.logo-flip .flip-card-back {
    background: linear-gradient(135deg, #4a9eff, #2d7acc);
    border: 5px solid #f5f5dc;
    border-radius: 20px;
}

.logo-text {
    font-family: 'Rubik Vinyl', cursive;
    font-size: 80px;
    color: var(--pink);
    letter-spacing: 4px;
}

.logo-back-image {
    max-height: 100px;
}

/* ===================================
   PROJECTS SECTION
   =================================== */
.projects-section {
    min-height: 100vh;
    background-color: var(--dark-bg);
    padding: 6rem 2rem;
}

/* Section Header */
.section-header {
    display: flex;
    justify-content: center;
    margin-bottom: 3rem;
}

.title-flip {
    width: auto;
    max-width: 500px;
}

.title-banner {
    background: var(--pink);
    border-radius: 12px;
    padding: 1rem 3rem;
    box-shadow: 0 4px 15px rgba(214, 76, 127, 0.3);
}

.section-title,
.section-title-back {
    font-family: 'Rubik Vinyl', cursive;
    font-size: 3rem;
    color: var(--neon-green);
    margin: 0;
    text-align: center;
}

/* Decorative GIF */
.decorative-gif-container {
    text-align: center;
    margin-bottom: 2rem;
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.6s ease;
}

.decorative-gif-container.visible {
    opacity: 1;
    transform: scale(1);
}

.decorative-gif {
    width: 200px;
    height: auto;
}

/* Category Filters */
.category-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
}

.filter-btn {
    background: transparent;
    border: 2px solid var(--neon-green);
    color: var(--cream);
    padding: 0.75rem 1.5rem;
    border-radius: 25px;
    cursor: pointer;
    font-family: 'Work Sans', sans-serif;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.filter-btn:hover,
.filter-btn.active {
    background: var(--neon-green);
    color: var(--darker-bg);
}

.filter-icon {
    font-size: 1.2rem;
}

/* Projects Grid */
.projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
}

.project-card {
    background: var(--darker-bg);
    border-radius: 15px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(30px);
}

.project-card.visible {
    opacity: 1;
    transform: translateY(0);
}

.project-card.hidden {
    display: none;
}

.project-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(184, 255, 60, 0.2);
}

.project-card.double-width {
    grid-column: span 1;
}

.project-card.full-width {
    grid-column: span 2;
}

.project-image {
    width: 100%;
    height: 300px;
    overflow: hidden;
    position: relative;
}

.project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

/* Static image - visible by default */
.project-static-img {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 1;
    transition: opacity 0.5s ease;
}

/* GIF - hidden by default */
.project-gif-img {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
}

/* When project card is in view, show GIF */
.project-card.in-view .project-static-img {
    opacity: 0;
}

.project-card.in-view .project-gif-img {
    opacity: 1;
}

.project-card:hover .project-image img {
    transform: scale(1.1);
}

.project-info {
    padding: 1.5rem;
}

.project-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--cream);
}

.project-category {
    color: var(--neon-green);
    font-size: 0.9rem;
    font-weight: 500;
}

/* ===================================
   ABOUT SECTION
   =================================== */
.about-section {
    min-height: 100vh;
    background-color: var(--darker-bg);
    padding: 6rem 2rem;
}

.about-content {
    max-width: 1200px;
    margin: 0 auto 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
}

.about-text {
    color: var(--cream);
}

.about-intro {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    line-height: 1.8;
}

.about-intro strong {
    color: var(--neon-green);
}

.about-poem {
    margin-bottom: 2rem;
}

.about-poem p {
    margin-bottom: 1rem;
}

.about-poem blockquote {
    border-left: 3px solid var(--pink);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
}

.about-poem blockquote p {
    margin-bottom: 0.5rem;
    line-height: 1.6;
}

.view-resume-btn {
    background: var(--neon-green);
    color: var(--darker-bg);
    border: none;
    padding: 1rem 2.5rem;
    border-radius: 30px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: 'Work Sans', sans-serif;
}

.view-resume-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 5px 20px rgba(184, 255, 60, 0.4);
}

.about-illustration img {
    width: 100%;
    max-width: 400px;
    border-radius: 15px;
}

/* About Bottom */
.about-bottom {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 3rem;
    align-items: center;
}

.about-portrait {
    width: 300px;
    height: 400px;
    background: var(--cream);
    border-radius: 15px;
    overflow: hidden;
}

.portrait-gif {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.about-tagline {
    background: var(--cream);
    color: var(--pink);
    padding: 2rem 3rem;
    border-radius: 15px;
    text-align: center;
}

.about-tagline h3 {
    font-family: 'Work Sans', sans-serif;
    font-size: 1.8rem;
    font-weight: 600;
    font-style: italic;
}

/* ===================================
   CONTACT SECTION
   =================================== */
.contact-section {
    min-height: 100vh;
    background-color: var(--dark-bg);
    padding: 6rem 2rem;
}

.contact-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
}

.contact-info {
    margin-bottom: 3rem;
}

.contact-item {
    margin-bottom: 1.5rem;
}

.contact-email,
.contact-phone {
    color: var(--cream);
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 600;
    transition: color 0.3s ease;
}

.contact-email:hover,
.contact-phone:hover {
    color: var(--neon-green);
}

.green-star {
    color: var(--neon-green);
    font-size: 2rem;
    margin-right: 1rem;
}

/* Social Icons */
.social-icons {
    display: flex;
    justify-content: center;
    gap: 2rem;
}

.social-link {
    display: block;
    transition: transform 0.3s ease;
}

.social-link:hover {
    transform: scale(1.2);
}

.social-icon {
    width: 60px;
    height: 60px;
    object-fit: contain;
}

/* ===================================
   RESUME MODAL
   =================================== */
.resume-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: rgba(0, 0, 0, 0.95);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
}

.resume-modal.active {
    opacity: 1;
    visibility: visible;
}

.resume-modal-content {
    width: 90%;
    max-width: 1000px;
    height: 90vh;
    background: white;
    border-radius: 15px;
    position: relative;
    display: flex;
    flex-direction: column;
}

.close-resume {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--pink);
    color: white;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s ease;
}

.close-resume:hover {
    background: var(--pink-light);
    transform: scale(1.1);
}

.download-resume-btn {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--neon-green);
    color: var(--darker-bg);
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 25px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    z-index: 10;
}

.download-resume-btn:hover {
    transform: scale(1.05);
}

.resume-iframe {
    width: 100%;
    height: 100%;
    border-radius: 15px;
}

/* ===================================
   PROJECT DETAIL MODAL
   =================================== */
.project-detail {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: var(--darker-bg);
    z-index: 9998;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    padding: 4rem;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    overflow-y: auto;
}

.project-detail.active {
    opacity: 1;
    visibility: visible;
}

.close-project {
    position: fixed;
    top: 2rem;
    right: 2rem;
    background: var(--pink);
    color: white;
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    font-size: 2rem;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s ease;
}

.close-project:hover {
    background: var(--pink-light);
    transform: scale(1.1);
}

.project-preview {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 100px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.project-preview.prev {
    left: 1rem;
}

.project-preview.next {
    right: 1rem;
}

.project-preview.hidden {
    display: none;
}

.project-preview:hover {
    transform: translateY(-50%) scale(1.1);
}

.project-preview-img {
    width: 100%;
    border-radius: 10px;
    margin-bottom: 0.5rem;
}

.project-preview-label {
    text-align: center;
    color: var(--cream);
    font-size: 0.8rem;
}

.project-detail-left {
    padding: 2rem;
}

.project-info-category {
    color: var(--neon-green);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
}

.project-info-title {
    font-size: 2.5rem;
    color: var(--cream);
    margin-bottom: 1.5rem;
}

.project-info-description {
    color: var(--cream);
    line-height: 1.8;
    margin-bottom: 2rem;
}

.project-nav-buttons {
    display: flex;
    gap: 1rem;
}

.nav-btn {
    background: transparent;
    border: 2px solid var(--neon-green);
    color: var(--cream);
    padding: 0.75rem 1.5rem;
    border-radius: 25px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
}

.nav-btn:hover {
    background: var(--neon-green);
    color: var(--darker-bg);
}

.project-detail-right {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 2rem;
}

.project-detail-right img {
    width: 100%;
    border-radius: 15px;
}

/* ===================================
   RESPONSIVE DESIGN
   =================================== */

/* Tablet */
@media (max-width: 1024px) {
    .container {
        max-width: 600px;
        height: 550px;
    }
    
    .image-flip {
        width: 300px;
        height: 300px;
    }
    
    .logo-flip {
        height: 100px;
    }
    
    .logo-text {
        font-size: 65px;
    }
    
    .sticker-1, .sticker-2, .sticker-3, .sticker-4 {
        max-width: 130px;
    }

    .projects-grid {
        gap: 1.5rem;
    }

    .about-content,
    .about-bottom {
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .about-illustration img {
        margin: 0 auto;
    }

    .about-bottom {
        justify-items: center;
    }

    .project-detail {
        grid-template-columns: 1fr;
        padding: 2rem;
    }
}

/* Mobile Landscape */
@media (max-width: 768px) {
    .section-title,
    .section-title-back {
        font-size: 2rem;
    }

    .container {
        max-width: 500px;
        height: 500px;
    }
    
    .image-flip {
        width: 250px;
        height: 250px;
    }
    
    .logo-flip {
        height: 90px;
    }
    
    .logo-text {
        font-size: 50px;
        letter-spacing: 2px;
    }
    
    .sticker-1 {
        top: 70px;
        left: 20px;
        max-width: 100px;
    }
    
    .sticker-2 {
        top: 50px;
        right: 20px;
        max-width: 120px;
    }
    
    .sticker-3 {
        top: 200px;
        left: 10px;
        max-width: 110px;
    }
    
    .sticker-4 {
        top: 180px;
        right: 15px;
        max-width: 120px;
    }

    .projects-grid {
        grid-template-columns: 1fr;
    }

    .project-card.double-width,
    .project-card.full-width {
        grid-column: span 1;
    }

    .category-filters {
        gap: 0.5rem;
    }

    .filter-btn {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
    }

    .social-icons {
        gap: 1rem;
    }

    .social-icon {
        width: 50px;
        height: 50px;
    }
}

/* Mobile Portrait */
@media (max-width: 480px) {
    .menu-button {
        top: 1rem;
        left: 1rem;
    }

    .menu-dropdown {
        left: 1rem;
        top: 4rem;
    }

    .container {
        max-width: 380px;
        height: 450px;
    }
    
    .image-flip {
        width: 200px;
        height: 200px;
    }
    
    .logo-flip {
        height: 80px;
    }
    
    .logo-text {
        font-size: 40px;
        letter-spacing: 1px;
    }
    
    .sticker-1, .sticker-2, .sticker-3, .sticker-4 {
        max-width: 85px;
    }
    
    .sticker-1 {
        top: 60px;
        left: 10px;
    }
    
    .sticker-2 {
        top: 45px;
        right: 10px;
    }
    
    .sticker-3 {
        top: 170px;
        left: 5px;
    }
    
    .sticker-4 {
        top: 160px;
        right: 10px;
    }

    .section-title,
    .section-title-back {
        font-size: 1.5rem;
    }

    .title-banner {
        padding: 0.75rem 2rem;
    }

    .projects-section,
    .about-section,
    .contact-section {
        padding: 4rem 1rem;
    }

    .project-info {
        padding: 1rem;
    }

    .project-title {
        font-size: 1.2rem;
    }

    .about-intro {
        font-size: 1rem;
    }

    .about-tagline h3 {
        font-size: 1.3rem;
    }

    .contact-email,
    .contact-phone {
        font-size: 1.2rem;
    }

    .project-detail {
        padding: 1rem;
    }

    .close-project {
        top: 1rem;
        right: 1rem;
        width: 40px;
        height: 40px;
    }
}

/* Very Small Mobile */
@media (max-width: 360px) {
    .container {
        max-width: 320px;
        height: 400px;
    }
    
    .image-flip {
        width: 170px;
        height: 170px;
    }
    
    .logo-text {
        font-size: 34px;
    }
    
    .sticker-1, .sticker-2, .sticker-3, .sticker-4 {
        max-width: 70px;
    }

    .loading-gif {
        width: 100px;
        height: 100px;
    }

    .loading-text {
        font-size: 1.5rem;
    }
}
